
{
  "expo": {
    "name": "Madhura Sales",
    "slug": "madhura-sales",
    "version": "1.0.0",
    "scheme": "madhura-sales",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/madhura.png",
    "splash": {
      "image": "./assets/madhura.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.madhura.sales"
    },
    "android": {
      "userInterfaceStyle": "light",
      "adaptiveIcon": {
        "foregroundImage": "./assets/madhura.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.madhura.sales"
    },
    "web": {
      "favicon": "./assets/madhura.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-image-picker",
      "expo-location",
      "expo-notifications",
      "expo-document-picker"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0983ff9d-2084-4405-8acb-80e24d2daa88"
      }
    }
  }
}
