{
  "expo": {
    "name": "Madhura Sales",
    "slug": "madhura-sales",
    "version": "1.0.0",
    "scheme": "madhura-sales",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/madhura.png",
    "splash": {
      "image": "./assets/madhura.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.madhura.sales"
    },
    "android": {
      "userInterfaceStyle": "light",
      "adaptiveIcon": {
        "foregroundImage": "./assets/madhura.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.madhura.sales",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/madhura.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-image-picker",
      "expo-location",
      "expo-document-picker",
      "expo-sharing",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9f3c67d3-2e8d-485e-821c-e2e517ade1f0"
      }
    }
  }
}
